# Tugether environment. Copy to .env.local and fill. Never commit real keys.

# Particle Network Universal Accounts (EIP-7702 mode, V2)
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=
PARTICLE_APP_ID=

# Magic embedded wallet (Google/email login)
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=

# ZeroDev (member smart account, gas sponsorship, session keys / programmable rules)
# lib/sdk/magic.ts and lib/sdk/smartAccount.ts currently target Arbitrum Sepolia
# (421614) for dev/testing -- switch both to Arbitrum One (42161) for the mainnet deploy.
NEXT_PUBLIC_ZERODEV_PROJECT_ID=
# v3 bundler+paymaster RPC from the ZeroDev dashboard: https://rpc.zerodev.app/api/v3/<project_id>/chain/421614
NEXT_PUBLIC_ZERODEV_RPC_URL=

# Manually deployed test USDC on Arbitrum Sepolia (via contracts/script/Deploy.s.sol).
# Used as the deposit token until Particle UA/mainnet wiring replaces it with real USDC.
NEXT_PUBLIC_TEST_USDC_ADDRESS=
# One sample vault from a manual cast-based test run. Not used by the app.
NEXT_PUBLIC_TEST_VAULT_ADDRESS=

# GoalVaultFactory on Arbitrum Sepolia (contracts/script/DeployFactory.s.sol). "Create Goal"
# calls this from the creator's own smart account to deploy a real, fresh GoalVault per goal.
NEXT_PUBLIC_GOALVAULT_FACTORY_ADDRESS=

# Arbitrum settlement (Sepolia testnet for now, see note above)
NEXT_PUBLIC_ARBITRUM_RPC_URL=
ARBITRUM_CHAIN_ID=421614

# Contracts deploy (Foundry). Never commit a funded private key.
ARBITRUM_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
ARBISCAN_API_KEY=
PRIVATE_KEY=

# Supabase Postgres (goal + members metadata only, non-custodial)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to 1 to show the maintenance screen for everyone
NEXT_PUBLIC_MAINTENANCE=0
