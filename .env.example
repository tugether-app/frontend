# Tugether environment. Copy to .env.local and fill. Never commit real keys.

# Particle Network Universal Accounts (EIP-7702 mode). REQUIRED -- this is the
# active chain-abstraction layer (ZeroDev SRA dropped, see CLAUDE.md). Get all
# three from dashboard.particle.network -> Project -> App.
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# Magic embedded wallet (Google/email login). The same EOA this returns gets
# upgraded to a Particle Universal Account in place via EIP-7702 -- no separate
# smart account address.
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=

# Manually deployed test USDC on Arbitrum Sepolia (via contracts/script/Deploy.s.sol).
# Kept for reference/local dev only -- Particle UA has no testnet, so live demos
# run on Arbitrum mainnet with the mainnet token address below instead.
NEXT_PUBLIC_TEST_USDC_ADDRESS=
# One sample vault from a manual cast-based test run. Not used by the app.
NEXT_PUBLIC_TEST_VAULT_ADDRESS=

# GoalVaultFactory. "Create Goal" calls this to deploy a real, fresh GoalVault
# per goal. Sepolia address for local dev; mainnet address for the live app.
NEXT_PUBLIC_GOALVAULT_FACTORY_ADDRESS=

# Arbitrum settlement -- mainnet (42161) for the live app, Particle UA has no testnet.
NEXT_PUBLIC_ARBITRUM_RPC_URL=
ARBITRUM_CHAIN_ID=42161

# Contracts deploy (Foundry). Never commit a funded private key.
ARBITRUM_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
ARBISCAN_API_KEY=
PRIVATE_KEY=

# Supabase Postgres (goal + members metadata only, non-custodial)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to 1 to show the maintenance screen for everyone
NEXT_PUBLIC_MAINTENANCE=0
